{
  "name": "health-nexus",
  "private": true,
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "scripts": {
    "format": "prettier --write . && npm run format:backend",
    "format:check": "prettier --check . && npm run format:check:backend",
    "format:frontend": "cd frontend-nexus && npm run format",
    "format:backend": "cd backend-nexus && (python3 -m black . || python -m black .)",
    "format:check:backend": "cd backend-nexus && (python3 -m black --check . || python -m black --check . || true)"
  }
}
