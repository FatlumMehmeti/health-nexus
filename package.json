{
  "name": "health-nexus",
  "private": true,
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0"
  },
  "scripts": {
    "format": "prettier --plugin=prettier-plugin-organize-imports --write . && npm run format:backend",
    "format:check": "prettier --plugin=prettier-plugin-organize-imports --check . && npm run format:check:backend",
    "format:frontend": "cd frontend-nexus && npm run format",
    "format:backend": "cd backend-nexus && (python3 -m black . || python -m black .)",
    "format:check:backend": "cd backend-nexus && (python3 -m black --check . || python -m black --check . || true)"
  }
}
