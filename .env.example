# Copy to .env and adjust values.
# Used by docker-compose for db and api.

# Postgres (db container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# API connection to db (use 'db' as host inside Docker)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/postgres

# Optional: Base URL for signature/image links (default http://localhost:8000)
API_BASE_URL=http://localhost:8000
# Or: API_HOST=localhost API_PORT=8000

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder_secret_key_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_placeholder_webhook_secret_replace_with_real_secret
VITE_STRIPE_PUBLIC_KEY=pk_test_placeholder_public_key_replace_with_real_key